VCAS_SOURCE_MODE=synthetic
VCAS_SCENARIO_PATH=scenarios/canonical/head_on.yml

# Optional browser/globe token. Synthetic radar demo does not require it.
VCAS_CESIUM_TOKEN=

# Optional OpenSky replay credentials.
VCAS_OPENSKY_USERNAME=
VCAS_OPENSKY_PASSWORD=
VCAS_REPLAY_AIRPORT=KAZO
VCAS_REPLAY_START_UTC=
VCAS_REPLAY_DURATION_S=600
VCAS_REPLAY_CACHE_ROOT=data/replay_cache

# Optional ML-risk service toggle.
VCAS_ML_ENABLED=false
VCAS_ML_ENDPOINT=
