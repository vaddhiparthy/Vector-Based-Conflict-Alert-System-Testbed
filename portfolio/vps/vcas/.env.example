# [REQ] minimal local demo (synthetic mode)
VCAS_SOURCE_MODE=synthetic
VCAS_SCENARIO_PATH=scenarios/canonical/head_on.yml
VCAS_AERODROME_LAT=42.2343889
VCAS_AERODROME_LON=-85.5515556
VCAS_AERODROME_ALT_M=100

# General runtime
VCAS_DEBUG=false
VCAS_LOG_LEVEL=INFO
VCAS_SURVEILLANCE_RATE_HZ=1
VCAS_SURVEILLANCE_CONFIG=config/surveillance.yaml
VCAS_CELL_SIZE_M=4000
VCAS_PROTECTED_RADIUS_M=1852
VCAS_PROTECTED_HEIGHT_M=609.6
VCAS_THREAD1_T_TC_S=900
VCAS_THREAD2A_T_TC_S=300
VCAS_PERSISTENT_CLOSE_SECONDS=15
VCAS_P_FP_WEIGHT=0.20
VCAS_P_PHYS_WEIGHT=0.30
VCAS_P_ML_WEIGHT=0.50

# [OPT] ML integration
VCAS_ML_ENABLED=false
VCAS_ML_SERVICE_URL=http://localhost:8080/predictions/vcas-lstm
VCAS_ML_TIMEOUT_S=1.2
VCAS_ML_CIRCUIT_FAILURE_THRESHOLD=3
VCAS_ML_CIRCUIT_OPEN_SECONDS=30

# [OPT] infra
VCAS_REDIS_URL=redis://localhost:6379/0
VCAS_POSTGRES_URL=postgresql+psycopg://vcas:vcas@localhost:5432/vcas
VCAS_MINIO_ENDPOINT=localhost:9000
VCAS_MINIO_ACCESS_KEY=
VCAS_MINIO_SECRET_KEY=

# [REQ_REPLAY] replay source
VCAS_REPLAY_AIRPORT=KAZO
VCAS_REPLAY_START_UTC=2026-01-01T00:00:00Z
VCAS_REPLAY_DURATION_S=3600
VCAS_REPLAY_CACHE_ROOT=cache/opensky
VCAS_OPENSKY_USERNAME=
VCAS_OPENSKY_PASSWORD=

# [OPT] extras
VCAS_FLIGHT_PLAN_WINDOW_S=30
VCAS_WIND_PROFILE=config/wind.yaml
VCAS_CESIUM_TOKEN=
TELEGRAM_BOT_TOKEN=
OPENWEATHER_API_KEY=
